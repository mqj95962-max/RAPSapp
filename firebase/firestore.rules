rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRole(role) {
      return signedIn()
        && userDocExists()
        && userDoc().data.roles is list
        && role in userDoc().data.roles;
    }

    function isAdmin() {
      return signedIn() && userDocExists() && (
        userDoc().data.get('isAdmin', false) == true ||
        hasRole('admin') ||
        hasRole('quartermaster') ||
        hasRole('archivist')
      );
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['roles', 'isAdmin']);
      allow delete: if isAdmin();
    }

    match /equipment/{equipmentId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // All signed-in users may read loans (needed for borrow-page availability + live sync).
    // Only admins can update; members may only create their own pending requests.
    match /loans/{loanId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin()
        || (
          isOwner(resource.data.userId)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['photosSubmitted', 'photosSubmittedAt'])
        );
      allow delete: if isAdmin() || isOwner(resource.data.userId);
    }

    match /formalEvents/{formalEventId} {
      allow read: if signedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['signupCount'])
        && request.resource.data.signupCount == resource.data.get('signupCount', 0) + 1
      );

      match /signups/{signupUserId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.auth.uid == signupUserId
          && request.resource.data.userId == request.auth.uid;
        allow delete: if isAdmin();
      }
    }
  }
}
