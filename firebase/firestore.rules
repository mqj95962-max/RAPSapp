rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRole(role) {
      return signedIn() && role in userDoc().data.roles;
    }

    function isQuartermaster() {
      return hasRole('quartermaster');
    }

    function isArchivist() {
      return hasRole('archivist');
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['roles']);
    }

    match /equipment/{equipmentId} {
      allow read: if signedIn();
      allow create, update, delete: if isQuartermaster();
    }

    match /categories/{categoryId} {
      allow read: if signedIn();
      allow create, update, delete: if isQuartermaster();
    }

    match /loans/{loanId} {
      allow read: if signedIn() && (
        isQuartermaster() ||
        resource.data.userId == request.auth.uid
      );
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isQuartermaster();
    }

    match /events/{eventId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isArchivist()
        || (
          isOwner(resource.data.userId)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['photosSubmitted', 'photosSubmittedAt'])
        );
    }
  }
}
